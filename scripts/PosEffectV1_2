    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return false end
    local fire_param = damage_param:get_field("_FireParam")
    if not fire_param then return false end
    local active =  fire_param:call("get_IsActive")
    local timer =   fire_param:call("get_ActiveTimer") or 0
    return active and timer > 0

end  

