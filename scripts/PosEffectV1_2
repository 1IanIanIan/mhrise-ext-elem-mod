function forceConditionDamage(condition)
    if type(condition) ~= "number" then
        return
    end
    force_flagelo_type = condition
    enabled = true
    

end

local _forcing_action = false

_G.get_field = function(obj, name)
    local td = obj:get_type_definition()
    local f = td:get_field(name)
    if not f then
        return nil
    end
    return f:get_data(obj)
end


_G.set_field = function(obj, backing_name, value)
    local td = obj:get_type_definition()
    local prop = backing_name:match("<(.*)>k__BackingField")
    if prop then
        local setter_name = "set_" .. prop
        local setter = td:get_method(setter_name)
        if setter then
            obj:call(setter_name, value)
            return
        end
    end
    local f = td:get_field(backing_name)
    if f then
        pcall(function() f:set_data(obj, value) end)
    end
end


_G.force_action = function(enemy, category, no)
    if _forcing_action then return end
    _forcing_action = true

    if not enemy or not sdk.is_managed_object(enemy) then
        _forcing_action = false
        return
    end

    local TD_Action = sdk.find_type_definition("snow.enemy.SetupActionData")
    local action = TD_Action:create_instance()

    local baseParam = get_field(action, "<BaseParam>k__BackingField")
    if baseParam then
        set_field(baseParam, "<Category>k__BackingField", category)
        set_field(baseParam, "<No>k__BackingField", no)
    end

    local extend = get_field(action, "<ExtendParam>k__BackingField")
    if extend then
        set_field(extend, "<ActOverWriteUniqueNo>k__BackingField", 0)
        set_field(extend, "<ActTuneUniqueVariationID>k__BackingField", 0)

        local f = extend:get_type_definition():get_field("_ActSpecialFlag")
        if f then pcall(function() f:set_data(extend, 0) end) end
    end

    local target = get_field(action, "<TargetParam>k__BackingField")
    if target then
        set_field(target, "<TurnAng>k__BackingField", 0.0)
    end

    pcall(function() enemy:call("requestActionSet", action) end)

    local Acao1 = enemy:call("get_ActionParam()")
    local No1 = Acao1:call("get_ActionNo()")

    _forcing_action = false
end



ParaliseEnded = false
local was_paralyzed = false

function CheckParalyzeEnd(enemy_obj)
    if not enemy_obj then 
        return 
    end

   
    local abnormal = enemy_obj:get_Field("_AbnormalStatus")
    if not abnormal then 
        return 
    end


    local slots = abnormal:get_Field("_StatusSlot")
    if not slots then 
        return 
    end

    local para_slot = slots[3]
    if not para_slot then 
        return 
    end

    local timer = para_slot:get_Field("<ActiveTimer>k__BackingField")
    if timer == nil then 
        return 
    end

    local is_paralyzed = timer > 0

 
    if was_paralyzed and not is_paralyzed then
        ParaliseEnded = true
    end

    was_paralyzed = is_paralyzed
end



do
    local td = sdk.find_type_definition("snow.enemy.EnemyCharacterBase")
    local m  = td and td:get_method("stockDamage")
    if m then
        sdk.hook(m,
        function(args)
            if not enabled then return end
            if not force_flagelo_type then return end

            local damage = sdk.to_managed_object(args[3])
            if not damage then return end

            local condition_type = force_flagelo_type
            local value = 12000.0  

            local ok = pcall(function()
                damage:call("set_IsConditionDamage", true)
                damage:call("set_IsStatusDamage", true)
                damage:call("set_ConditionDamageType", condition_type)
                damage:call("set_ConditionDamage", value)
                damage:call("set_StatusEffectEmType", condition_type)
            end)

            if ok then
                
                -- consome o trigger
                force_flagelo_type = nil
                enabled = false
            else
            end

            args[3] = sdk.to_ptr(damage)
        end,
        function(retval) return retval end
    )
    end
end



