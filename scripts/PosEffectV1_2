function StartCallNearBossEnemy(enemy, duration)
    if not enemy or not duration then return end
    IceOk[enemy] = true
    NearBossTask[enemy] = {
        start_time = os.clock(),
        duration = duration
    }

end






re.on_frame(function()
    if not NearBossTask then return end

    local now = os.clock()

    for ownerEnemy, data in pairs(NearBossTask) do
        if not ownerEnemy or not sdk.is_managed_object(ownerEnemy) then
            NearBossTask[ownerEnemy] = nil
        else
            if (now - data.start_time) <= data.duration then

                local ok, nearEnemy = pcall(function()
                    return ownerEnemy:call("getNearBossEnemy()")
                end)

                if ok and nearEnemy and sdk.is_managed_object(nearEnemy) then
                    local damage_param = nearEnemy:call("get_DamageParam")
                    if damage_param then
                        local ice_param = damage_param:get_field("_IceParam")
                        if ice_param then
                            pcall(function()
                                ice_param:call(
                                    "activate(snow.enemy.EnemyDef.ConditionDamageParamType)",
                                    0
                                )
                            end)
                        end
                    end
                end
            else
                NearBossTask[ownerEnemy] = nil
            end
        end
    end
end)
function WatchEnemyActionCategory(enemy, duration)
    if not enemy or not duration then return end

    if enableWa[enemy] then return end

    local now = os.clock()
    if action_watch_cooldown[enemy] and now < action_watch_cooldown[enemy] then
        return
    end


    ActionWatchTask[enemy] = {
        start_time    = now,
        duration      = duration,
        last_category = -1,
    }

    enableWa[enemy] = true
    ActionWatchSuppress[enemy] = nil

end


local function zero_and_capture_addlimit(enemy)
    if not enemy or not sdk.is_managed_object(enemy) then return false end

    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return false end

    local paralyze_param = damage_param:get_field("_ParalyzeParam")
    if not paralyze_param then return false end

    local old = paralyze_param:call("get_AddLimit")
    if not old then return false end

    local len = old:call("get_Length")
    if len <= 0 then return false end

    if not addL[enemy] then
        addL[enemy] = {}
        for i = 0, len - 1 do
            addL[enemy][i] = old[i]  
        end


        
    end

    -- zera
    local arr = sdk.create_managed_array("System.Single", len)
    for i = 0, len - 1 do
        arr[i] = 0.0
    end

    paralyze_param:call("set_AddLimit(System.Single[])", arr)

    return true
end
local function restore_addlimit(enemy, paralyze_param)
    if not enemy or not sdk.is_managed_object(enemy) then return false end
    if not paralyze_param or not sdk.is_managed_object(paralyze_param) then return false end
    if not addL or not addL[enemy] then
        return false
    end

    local old = paralyze_param:call("get_AddLimit")
    if not old then
        return false
    end

    local len = old:get_Length()
    if len <= 0 then return false end

    local arr = sdk.create_managed_array("System.Single", len)

    for i = 0, len - 1 do
        local v = addL[enemy][i]

        if type(v) ~= "number" or v ~= v or v == math.huge or v == -math.huge then
            v = tonumber(old[i]) or 0.0
        end

        arr[i] = v
    end

    paralyze_param:call("set_AddLimit(System.Single[])", arr)

  

    addL[enemy] = nil

    return true
end


function EnsureDamageStock(enemy)
    if not enemy then return nil end

    local params = enemy:call("get_DamageParam()")
    if not params then return nil end

    local st = params:call("get_DamageStock()")

   
    if st then
        local count = st:get_field("_size")
        if count and count > 0 then
            return st
        end
    end


    local stockType = sdk.find_type_definition(
        "snow.enemy.EnemyDamageStockParam"
    )
    if not stockType then
        return nil
    end

    local newStock = sdk.create_instance(stockType)
    if not newStock then
        return nil
    end

    
    local listType = sdk.find_type_definition(
        "System.Collections.Generic.List`1[snow.enemy.EnemyDamageStockParam]"
    )
    if not listType then
        return nil
    end

    local list = sdk.create_instance(listType)
    list:call("Add", newStock)


    params:call(
        "set_DamageStock(System.Collections.Generic.List`snow.enemy.EnemyDamageStockParam)",
        list
    )


    return list
end
re.on_frame(function()
    if not ActionWatchTask then return end
    local now = os.clock()
    for enemy, data in pairs(ActionWatchTask) do
        if not enemy or not sdk.is_managed_object(enemy) then
            ActionWatchTask[enemy] = nil
        else
            if (now - data.start_time) <= data.duration then

                if ActionWatchSuppress[enemy] then
                    if os.clock() - ActionWatchSuppress[enemy] < 0.3 then
                        goto continue_enemy
                    else
                        ActionWatchSuppress[enemy] = nil
                    end
                end

                local ok, actionParam = pcall(function()
                    return enemy:call("get_ActionParam()")
                end)

                if ok and actionParam then
                    local ok2, category = pcall(function()
                        return actionParam:call("get_ActionCategory()")
                    end)

                    if ok2 then
                        if category == 4 and data.last_category ~= 4 then
                            ActionWatchSuppress[enemy] = os.clock()

                            local dmg_param = enemy:call("get_DamageParam")
                            if dmg_param then
                                local paralyze_param = dmg_param:get_field("_ParalyzeParam")
                                if paralyze_param then
                                    if ParaTime[enemy] == nil then
                                        ParaTime[enemy] = paralyze_param:call("get_ActiveTime()")
                                    end
                                    paralyze_param:call("set_ActiveTime", 0.1)
                                    if not paralyze_cycle_done[enemy] then
                                        zero_and_capture_addlimit(enemy)
                                        contPA2[enemy] = true
                                        paralyze_cycle_done[enemy] = false
                                    end

                                end    
                                SpawnConditionVisual(enemy, 0, "Orange", 0.1, 0.8, false, 1.0)

                                enemy:call(
                                    "stockDirectConditionDamage(System.Single, snow.enemy.EnemyDef.ConditionDamageType)",
                                    999.0,
                                    0
                                )

                                ParalyzeByScript[enemy] = os.clock()
                            end
                        end
                           
                        data.last_category = category
                    end
                end
            else
            enableWa[enemy] = false
            ActionWatchTask[enemy] = nil

            action_watch_cooldown[enemy] = os.clock() + 1.0  -- ajuste: 0.5~1.5s
            local dmg_param = enemy:call("get_DamageParam")
            local paralyze_param 
            if dmg_param and paralyze_param and ParaTime[enemy] then
                local dura = paralyze_param:call("get_ActiveTime")
                paralyze_param:call("set_ActiveTime", ParaTime[enemy])
            end

            if dmg_param and paralyze_param and ParaTime[enemy] then
                paralyze_param:call("set_ActiveTime",ParaTime[enemy])
                if contPA2[enemy] == true then
                    restore_addlimit(enemy, paralyze_param)
                    addL[enemy] = nil

                    paralyze_cycle_done[enemy] = true
                end


            end 
            end
        end
        ::continue_enemy::
    end
end)
re.on_frame(function()
    if not ActionWatchTaskPending then return end

    local now = os.clock()

    for enemy, data in pairs(ActionWatchTaskPending) do
        if not enemy or not sdk.is_managed_object(enemy) then
            ActionWatchTaskPending[enemy] = nil
        elseif now >= data.when then
            WatchEnemyActionCategory(enemy, data.duration)
            ActionWatchTaskPending[enemy] = nil
        end
    end
end)

local timers = {}

local function start_timer(seconds, on_finish, enemy)
    local id = {}

    timers[id] = {
        start = os.clock(),
        duration = seconds,
        callback = on_finish,
        enemy = enemy
    }

    return id
end
re.on_frame(function()
    local now = os.clock()

    for id, t in pairs(timers) do
        if now - t.start >= t.duration then
            if t.callback then
                t.callback(t.enemy)
            end

            timers[id] = nil
        end
    end
end)

local function extend_paralyze_now(enemy_obj, extra_time)
    if not enemy_obj or not sdk.is_managed_object(enemy_obj) then return false end

    local dmg_param = enemy_obj:call("get_DamageParam")
    if not dmg_param then return false end

    local para_param = dmg_param:get_field("_ParalyzeParam")
    if not para_param then return false end

    local cur_time = para_param:call("get_ActiveTime()") or 0

    para_param:call("set_IsActive", true)
    para_param:call("set_ActiveTime", cur_time + extra_time)

    return true, cur_time + extra_time
end

_G.onVenomHitDetected = function(category, damage, time, monster_name, monster_size, enemy_obj)



    if not enemy_obj then return end

    if category == "FORTE" then
        ajustar_damage_interval(enemy_obj, 0.60)
        aumentar_dano_veneno(enemy_obj, 1.41)
        nextPaintRequest = { colors = {"Red", "Red"}, expire = os.clock() + 1.5, speed = 1.75 }
        venom_monitors[enemy_obj] = true

    elseif category == "MEDIO" then
        ajustar_damage_interval(enemy_obj, 0.60)
        aumentar_dano_veneno(enemy_obj, 1.16)

        nextPaintRequest = { colors = {"LightRed", "LightRed"}, expire = os.clock() + 1.5, speed = 1.5 }
        venom_monitors[enemy_obj] = true
    end

    if category == "FORTE0" then
        paralyze_cycle_done[enemy_obj] = false
        contPA2[enemy_obj] = false
        nextPaintRequest = { colors = {"Orange", "Orange"}, expire = os.clock() + 1.5, speed = 2.5 }

        local dmg_param = enemy_obj:call("get_DamageParam")
        local paralyze_param = dmg_param:get_field("_ParalyzeParam")
        local dura = paralyze_param:call("get_ActiveTime()") 
        
            if contPA2[enemy_obj] == false then
           
                action_watch_cooldown[enemy_obj] = os.clock() + 1.0
                SpawnConditionVisual(enemy_obj, 0, "DkGray", 0.1, 0.8, false, (dura/2)+3+dura)
             
                ActionWatchTaskPending = ActionWatchTaskPending or {}
                ActionWatchTaskPending[enemy_obj] = {
                    when = os.clock() + 1.0,
                    duration = (dura/2)+3+dura
                }
            end
            paralyze_finished[enemy_obj] = true

            caminho = 0

        action_watch_cooldown[enemy_obj] = os.clock() + 1.0

        caminho = 0
       
    elseif category == "MEDIO0" then
        nextPaintRequest = { colors = {"LtGray", "LtGray"}, expire = os.clock() + 1.5, speed = 1.5 }

        paralyze_finished[enemy_obj] = true
        timerPA[enemy_obj] = true
        
        local dmg_param = enemy_obj:call("get_DamageParam")
        local paralyze_param = dmg_param:get_field("_ParalyzeParam")
        local dura = paralyze_param:call("get_ActiveTime()") 
        

        if contPA[enemy_obj] == false then
            SpawnConditionVisual(enemy_obj, 2, "LtGray", 0.1, 1.5, false, dura + 10.0)
            SpawnConditionVisual(enemy_obj, 3, "LtGray", 0.1, 1.5, false, dura + 10.0)


            timerPA[enemy_obj] = true
            start_timer(dura + 10.0, function(e)
            if not e or not sdk.is_managed_object(e) then return end
                timerPA[e] = false
            end, enemy_obj)
        end    

    end


    if category == "FORTE9" then
        nextPaintRequest = { colors = {"Blue", "Blue"}, expire = os.clock() + 1.5, speed = 1.5 }
        ajustar_damageFire(enemy_obj)
        fire_monitors[enemy_obj]= true
    elseif category == "MEDIO9" then
        nextPaintRequest = { colors = {"DarkOrange", "DarkOrange"}, expire = os.clock() + 1.5, speed = 0.7 }
        ajustar_damageFire(enemy_obj)
        fire_monitors[enemy_obj]= true


    end

    
    if category == "FORTE10" then
        nextPaintRequest = { colors = {"White", "White"}, expire = os.clock() + 1.5, speed = 1.5 }
        local damage_param = enemy_obj:call("get_DamageParam")
        if damage_param then
            local ice_param = damage_param:get_field("_IceParam")
            if ice_param then
                local ok, err = pcall(function()
                    local mov = ice_param:call("get_MotionSpeedRate")
                    if IceMov[enemy_obj] == nil then
                        IceMov[enemy_obj] = mov
                    end    
                    ice_monitors[enemy_obj]= true
                    ice_param:call("set_MotionSpeedRate(System.Single)",(mov*0.5))
                    local tempo = ice_param:call("get_ActiveTime()")
                    local quest = print_quest_level()
                    if quest ~= 256 then 
                        StartCallNearBossEnemy(enemy_obj, tempo)
                    else
                        ice_param:call("set_MotionSpeedRate(System.Single)",(mov*0.6))
                    end    
                end)
                if ok then
                else
                end
            else
            end
        else
        end
    elseif category == "MEDIO10" then
        nextPaintRequest = { colors = {"White", "White"}, expire = os.clock() + 1.5, speed = 1.5 }
        local damage_param = enemy_obj:call("get_DamageParam")
        if damage_param then
            local ice_param = damage_param:get_field("_IceParam")
            if ice_param then
                local ok, err = pcall(function()
                    local mov = ice_param:call("get_MotionSpeedRate")
                    if IceMov[enemy_obj] == nil then
                        IceMov[enemy_obj] = mov
                    end    
                    ice_monitors[enemy_obj]= true

                    ice_param:call("set_MotionSpeedRate(System.Single)",(mov*0.7))
                end)
                if ok then
                else
                end
            else
            end
        else
        end


    end

    if category == "FORTE8" then
        nextPaintRequest = { colors = {"Orange", "Orange"}, expire = os.clock() + 1.5, speed = 0.6 }
        water_monitors[enemy_obj] = true
        enableW[enemy_obj] = true
    elseif category == "MEDIO8" then
        nextPaintRequest = { colors = {"Brown", "Brown"}, expire = os.clock() + 1.5, speed = 0.8 }
        water_monitors[enemy_obj] = true

    end

    if category == "FORTE1" then
        nextPaintRequest = { colors = {"Blue", "Blue"}, expire = os.clock() + 1.5, speed = 1.5 }
        local damage_param = enemy_obj:call("get_DamageParam")
        
           
    elseif category == "MEDIO1" then
        nextPaintRequest = { colors = {"Orange", "Orange"}, expire = os.clock() + 1.5, speed = 0.5 }
        enemy_obj:call("startMarionette")
        local damage_param = enemy_obj:call("get_DamageParam")
       

    end


    if category == "FORTE11" then
        nextPaintRequest = { colors = {"DarkGreen", "DarkGreen"}, expire = os.clock() + 1.5, speed = 1.5 }
        
    elseif category == "MEDIO11" then
        nextPaintRequest = { colors = {"Orange", "Orange"}, expire = os.clock() + 1.5, speed = 0.5 }
       

    end
    

    
end

re.on_frame(function()
    if nextPaintRequest and nextPaintRequest.expire and os.clock() > nextPaintRequest.expire then
        nextPaintRequest = nil
    end
    if pendingPaint and pendingPaint.expire and os.clock() > pendingPaint.expire then
        pendingPaint = nil
    end
    for enemy, _ in pairs(venom_monitors) do
        if not is_poison_active(enemy) then
            reset_poison_modifications(enemy)
        end
        
    end

    for enemy, _ in pairs(fire_monitors) do
        if not is_fire_ative(enemy)then
            reset_fire_modifications(enemy)
        end
    end  
    for enemy, _ in pairs(ice_monitors) do
        if not is_ice_ative(enemy)then
            reset_ice_modifications(enemy)
        end
    end 
    for enemy, _ in pairs(water_monitors) do
        if not is_water_ative(enemy)then
            reset_water_modifications(enemy)
        end
    end 
    
end)
