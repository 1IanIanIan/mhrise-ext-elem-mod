local last_container_id = nil
local last_element_id = nil
local nextPaintRequest = nil   
local pendingPaint = nil       

do
    local ObjectEffectManagerTD = sdk.find_type_definition("via.effect.script.ObjectEffectManager")
    local methods = {
        "requestEffect(via.effect.script.EffectID, via.GameObject, System.Int32, via.effect.script.EffectManager.WwiseTriggerInfo)",
        "requestEffect(via.effect.script.EffectID, via.vec3, via.Quaternion, via.GameObject, System.String, via.effect.script.EffectManager.WwiseTriggerInfo)",
        "requestEffect(via.effect.script.EffectID, via.vec3, via.Quaternion, via.mat4, via.GameObject, System.String, via.effect.script.EffectManager.WwiseTriggerInfo)",
        "requestEffectInternal(via.effect.script.EffectID, via.GameObject, System.Int32, via.effect.script.EffectManager.WwiseTriggerInfo, via.effect.script.EffectManager.RequestOverwriteParam)"
    }
    for _, sig in ipairs(methods) do
        local m = ObjectEffectManagerTD:get_method(sig)
        if m then
            sdk.hook(m,
                function(args)
                    local effectID = sdk.to_managed_object(args[3])
                    if effectID then
                        last_container_id = effectID.ContainerID
                        last_element_id   = effectID.ElementID
                    end
                end,
                function(retval) return retval end
            )
        end
    end
end

sdk.hook(
    sdk.find_type_definition("snow.SnowEffectManager"):get_method("eventBeforeCreateEffect(via.effect.script.EffectManager.BeforeCreateEffectInfo)"),
    function(args)
        if not nextPaintRequest then return end
        local snowEffectManager = sdk.to_managed_object(args[3])
        if not snowEffectManager then return end

        local userSingleton = sdk.get_managed_singleton("snow.player.PlayerManager")
        local user = userSingleton and userSingleton:findMasterPlayer()
        local userObj = user and user:get_GameObject()
        local caller = 2
        if snowEffectManager:get_Owner() == userObj or snowEffectManager:get_FollowTarget() == userObj then
            caller = 1
        end
        if caller ~= 2 then return end

        local key = tostring(last_container_id) .. "|" .. tostring(last_element_id)
        if target_env_effects[key] then
            pendingPaint = {
                key = key,
                colors = nextPaintRequest.colors,
                expire = os.clock() + 1.5,
                speed = nextPaintRequest.speed
            }
            nextPaintRequest = nil
        end
    end,
    function(retval) return retval end
)
sdk.hook(
    sdk.find_type_definition("snow.SnowEffectManager"):get_method("eventAfterCreateEffect(via.effect.script.EffectManager.AfterCreateEffectInfo)"),
    function(args)
        if not pendingPaint then return end
        if pendingPaint.expire and os.clock() > pendingPaint.expire then
            pendingPaint = nil
            return
        end

        local effectObject = sdk.to_managed_object(args[3])
        if not effectObject then
            pendingPaint = nil
            return
        end

        local effectContainer = effectObject:get_Container()
        if effectContainer then
            if pendingPaint.speed then
                pcall(function()
                    if effectContainer.setPlaySpeed then
                        effectContainer:setPlaySpeed(pendingPaint.speed)
                    elseif effectContainer.set_Speed then
                        effectContainer:set_Speed(pendingPaint.speed)
                    elseif effectContainer.setSpeed then
                        effectContainer:setSpeed(pendingPaint.speed)
                    elseif effectContainer:get_type_definition():get_field("Speed") then
                        effectContainer:set_field("Speed", pendingPaint.speed)
                    else
                    end
                end)
            end

            for _, cname in ipairs(pendingPaint.colors) do
                local c = color_map[cname]
                if c then
                    pcall(function() effectContainer:setRootColor(c) end)
                end
            end
        end

        pendingPaint = nil
    end,
    function(retval) return retval end
)
local function ajustar_damageFire(enemy)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return end
    local fire_param = damage_param:get_field("_FireParam")
    if not fire_param then return end
    if modified_fire_params[fire_param] then return end
    local current_damage = fire_param:get_field("<Damage>k__BackingField")
    local adjust_rate = fire_param:get_field("<FireDamageAdjustRateByEnemyLv>k__BackingField")
    if not current_damage or current_damage <= 0 then return end
    if not adjust_rate or adjust_rate <= 0 then return end
    if original_fire_damage[enemy] == nil then
        original_fire_damage[enemy] = current_damage
    end

    local novo_dano = current_damage + 5
    fire_param:set_field("<Damage>k__BackingField", novo_dano)
    modified_fire_params[fire_param] = true
    

end    

local function ajustar_damageEintervaloWater(enemy)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return end
    local water_param = damage_param:get_field("_WaterParam")
    if not water_param then return end
    if modified_water_params[water_param] then return end
    local poisonBaseAd = damage_param:get_field("_PoisonParam")
    if not poisonBaseAd then return end
    local adjust_rate = poisonBaseAd:get_field("<PoisonDamageAdjustRateByEnemyLv>k__BackingField")
    if not adjust_rate or adjust_rate <= 0 then return end    
    local novo_dano = 1.5 * adjust_rate 
    water_param:set_field("<Damage>k__BackingField", 1)
    water_param:set_field("<IsUseSlipDamage>k__BackingField",true)
    water_param:call("set_IsUseSlipDamage()",true)
    water_param:set_field("<DamageInterval>k__BackingField",0.5)
    enemy:call("setEnemyMotSpeed(snow.enemy.EnemyDef.EnemyMotSpeedType, System.Single)",0,0.8)
    enableW[water_param] = true
    modified_water_params[water_param] = true


end    



local function ajustar_damage_interval(enemy, fator_multiplicador)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return end
    local poison_param = damage_param:get_field("_PoisonParam")
 
    if not poison_param then return end
   
    

    local atual = poison_param:call("get_DamageInterval")
    if not atual then return end
    if original_intervals[enemy] == nil then
        original_intervals[enemy] = atual
    end
    local novo_valor = atual * fator_multiplicador

    local limite_min = 0.05
    if novo_valor < limite_min then novo_valor = limite_min end
    poison_param:call("set_DamageInterval", novo_valor)

end



local function aumentar_dano_veneno(enemy, multiplicador)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return end
    local poison_param = damage_param:get_field("_PoisonParam")
    if not poison_param then return end
    if modified_poison_params[poison_param] then return end
    local current_damage = poison_param:get_field("<Damage>k__BackingField")
    local adjust_rate = poison_param:get_field("<PoisonDamageAdjustRateByEnemyLv>k__BackingField")
    if not current_damage or current_damage <= 0 then return end
    if not adjust_rate or adjust_rate <= 0 then return end
    if original_poison_damage[enemy] == nil then
        original_poison_damage[enemy] = current_damage
    end
    local novo_dano = current_damage * multiplicador
    poison_param:set_field("<Damage>k__BackingField", novo_dano)
    modified_poison_params[poison_param] = true
end

local function reset_poison_modifications(enemy)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if damage_param then
        local poison_param = damage_param:get_field("_PoisonParam")
        if poison_param then
            if original_intervals[enemy] then
                poison_param:call("set_DamageInterval", original_intervals[enemy])
            end
            if original_poison_damage[enemy] then
                poison_param:set_field("<Damage>k__BackingField", original_poison_damage[enemy])
            end
            modified_poison_params[poison_param] = nil
        end
    end
    original_intervals[enemy] = nil
    original_poison_damage[enemy] = nil
    venom_monitors[enemy] = nil
end

local paralyze_monitors = {}
local paralyze_recasts = {} 

local function is_paralysis_active(enemy)
    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return false end
    local paralyze_param = damage_param:get_field("_ParalyzeParam")
    if not paralyze_param then return false end
    local active = paralyze_param:call("get_IsActive")
    local timer = paralyze_param:call("get_ActiveTimer") or 0
    return active and timer > 0
end

local function monitor_paralysis(enemy)
    paralyze_monitors[enemy] = true

end

local pending_deactivates = {} 

_G.force_action_after_delay = function(enemy, category, no_value, delay_seconds, cond)
    if not enemy or not sdk.is_managed_object(enemy) then
        return
    end

    if no_value == nil then
        return
    end

    local frames_elapsed = 0
    local frames_to_wait = math.floor(delay_seconds * 60)

    local active = true

    re.on_frame(function()
        if not active then return end  

        frames_elapsed = frames_elapsed + 1

        if frames_elapsed >= frames_to_wait then

            if cond then
                SpawnConditionVisual(enemy, 0, "Orange", 0.1, 2.0, false, 2.5)
            end

            force_action(enemy, category, no_value)

            active = false
        end
    end)
end


local function reset_fire_modifications(enemy)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if damage_param then
        local fire_param = damage_param:get_field("_FireParam")
        if fire_param then
            if original_fire_damage[enemy] then
                fire_param:call("set_Damage", original_fire_damage[enemy])
            end
            FireOk[enemy] = false
            modified_fire_params[fire_param] = nil
        end
    end
    
    original_fire_damage[enemy] = nil

end

local function reset_ice_modifications(enemy)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if damage_param then
        local Ice_param = damage_param:get_field("_IceParam")
        if Ice_param then
            Ice_param:call("set_MotionSpeedRate(System.Single)",IceMov[enemy])
            if IceOk[enemy]then

            end
            IceMov[enemy] = nil
            IceOk[enemy] = false
        end
    end
    
end

local function reset_water_modifications(enemy)
    if not enemy then return end
    local damage_param = enemy:call("get_DamageParam")
    if damage_param then
        local water_param = damage_param:get_field("_WaterParam")
        if water_param then
            if enableW[enemy] == true then
                water_param:set_field("<IsUseSlipDamage>k__BackingField",false)
                enableW[enemy] = false
                enemy:call("setEnemyMotSpeed(snow.enemy.EnemyDef.EnemyMotSpeedType, System.Single)",0,1.0)
            end    
            modified_water_params[enemy] = false
        end
    end  

    
end

