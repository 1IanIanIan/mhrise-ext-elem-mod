local function install_quest_hook()
    if quest_hook_installed then return end

    local qm_td = sdk.find_type_definition("snow.QuestManager")
    if not qm_td then
        return
    end

    local method = qm_td:get_method("getActiveQuestUniqueNo()")
    if not method then
        return
    end

    sdk.hook(
        method,
        function(args)
            return args
        end,
        function(retval)
            return retval
        end
    )

    quest_hook_installed = true
end

install_quest_hook()
local function print_quest_level()
    local qm = sdk.get_managed_singleton("snow.QuestManager")
    if not qm then return end
    questNo = qm:call("get_ActiveQuestNo()")
    quest = qm:call("getQuestType()")
    if not quest then return end
    return quest
end


local function delay(seconds, callback)
    if type(callback) ~= "function" then
        return
    end

    local start = os.clock()

    local function wrapped()
        local ok, result = pcall(function()
            if os.clock() - start >= seconds then
                callback()
                return false -- remove callback do on_frame
            end
        end)

        if not ok then
            return false -- remover mesmo assim
        end

        return result
    end

    re.on_frame(wrapped)
end





