        if cont then
            last_created_container = cont
        end
    end,

    function(retval) return retval end
)


local function modify_effect(container, color, speed)
    if not container then return end
    if not color then return end

    local tdef = container:get_type_definition()
    if not tdef then return end

    -- método real do MHRise
    local set_root_color = tdef:get_method("setRootColor(via.Color)")
    if set_root_color then
        pcall(function()
            container:call("setRootColor(via.Color)", color)
        end)
    end

    if speed then
        pcall(function()
            if container.setPlaySpeed then
                container:setPlaySpeed(speed)
            end
        end)
    end
end


function SpawnEffectCustom(pos, containerID, elementID, speed, color_name, duration)
    local playerMan = sdk.get_managed_singleton("snow.player.PlayerManager")
    if not playerMan then return end

    local user = playerMan:call("findMasterPlayer")
    if not user then return end

    local userGO = user:get_GameObject()
    if not userGO then return end

    local fxman = userGO:call(
        "getComponent(System.Type)",
        sdk.typeof("via.effect.script.ObjectEffectManager")
    )
    if not fxman then return end


    local effectID = sdk.create_instance("via.effect.script.EffectID", true):add_ref()
    effectID.ContainerID = containerID
    effectID.ElementID   = elementID

    local req = fxman:get_type_definition():get_method(
        "requestEffect(via.effect.script.EffectID, via.vec3, via.Quaternion, via.GameObject, System.String, via.effect.script.EffectManager.WwiseTriggerInfo)"
    )

    local trigger = sdk.create_instance(
        "via.effect.script.EffectManager.WwiseTriggerInfo", true
    ):add_ref()

    local rot = Quaternion.new(0, 0, 0, 1)

  
    req:call(fxman, effectID, pos, rot, nil, nil, trigger)


    local container = last_created_container
    if not container then
        return nil
    end


    if color_name and color_name ~= "" then
        local viaColor = sdk.create_instance("via.Color", true):add_ref()
        viaColor:call(".cctor()")

        local base = viaColor[color_name]
        if base then
            local newColor = viaColor:call(
                "op_Multiply(via.Color, via.Color)",
                base, base
            )
            container:setRootColor(newColor)
        end
    end

    if speed and speed ~= 1 then
        container:setPlaySpeed(speed)
    end


    if duration and duration > 0 then
        local start_time = os.clock()
        local fx = container
        local frame_handle

        frame_handle = re.on_frame(function()
            if not fx or not sdk.is_managed_object(fx) then
                if frame_handle then
                    re.remove_event_listener(frame_handle)
                    frame_handle = nil
                end
                return
            end

            if os.clock() - start_time >= duration then
                pcall(function()
                    fx:finishAll()
                    fx:finishAllInternal()
                end)

                fx = nil

                if frame_handle then
                    re.remove_event_listener(frame_handle)
                    frame_handle = nil
                end
            end
        end)
    end

    return container
end


local _forcing_action = false

local function get_field(obj, name)
    local td = obj:get_type_definition()
    local f = td:get_field(name)
    if not f then
        return nil
    end
    return f:get_data(obj)
end
addDragao = addDragao or {}
dragaoTime = dragaoTime or {}

function iniciaDragon(enemy)
    if not enemy or not sdk.is_managed_object(enemy) then return end
    if cond_dragao[enemy] == nil then  cond_dragao[enemy] = 0 end
    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return end
    drageffect[enemy] = 0
    local thunder_param = damage_param:get_field("_ThunderParam")
    dragaoTime[enemy] = thunder_param:call("get_ActiveTime()")

    if dragaoTime[enemy] == 0.0 or dragaoTime[enemy] == nil then thunder_param = damage_param:get_field("_ParalyzeParam") end
    if not thunder_param then return end
    dragaoTime[enemy] = thunder_param:call("get_ActiveTime()") + 5.0
    if dragaoTime[enemy] == nil or dragaoTime[enemy] == 0.0 then dragaoTime[enemy] = nil end
    if dragaoTime[enemy] == 40.0 then
        addDragao[enemy] = 137
    else
        addDragao[enemy] = 130 
    end
    if not atvdragao[enemy] then
        atvdragao[enemy] = false
    end


    if not dragao[enemy] then
        dragao[enemy] = 180
    end
end
function WaitEnemyHitData(enemy, on_found)
    if not enemy or not sdk.is_managed_object(enemy) then
        return false
    end

    if aguardando_hitdata[enemy] then
        return false
    end

    local RSC = enemy:call("getEnemyRSCController()")
    if not RSC then
        return false
    end
    aguardando_hitdata[enemy] = {
        RSC = RSC,
        callback = on_found
    }

    return true
end

re.on_frame(function()
    for enemy, data in pairs(aguardando_hitdata) do
        if not enemy or not sdk.is_managed_object(enemy) then
            aguardando_hitdata[enemy] = nil
        else
            local attacks = data.RSC:call("get_AttackWorks()")
            if attacks and attacks.get_size then
                for i = 0, attacks:get_size() - 1 do
                    local attack = attacks:get_element(i)
                    if attack then
                        local hit_data = attack:call("get_HitData")
                        if hit_data and sdk.is_managed_object(hit_data) then

                            -- callback opcional
                            if data.callback then
                                pcall(data.callback, enemy, hit_data)
                            end

                            -- remove: não escaneia mais esse enemy
                            aguardando_hitdata[enemy] = nil
                            break
                        end
                    end
                end
            end
        end
    end
end)


function HookEnemyManagerAttackRateTimed(difficulty_id, attack_rate_value, enemy, duration_seconds)
    local enabled = true
    local start_time = os.clock()

    baseAtk = baseAtk or {}

    -- EnemyManager
    local enemy_manager_td = sdk.find_type_definition("snow.enemy.EnemyManager")
    if not enemy_manager_td then
        return
    end

    local hook_method = enemy_manager_td:get_method("getBossEnemySameBlock(System.Int32)")
    if not hook_method then
    
        return
        
    end
    sdk.hook(
        hook_method,
        function(args)
            if not enabled then
                return args
            end
            if os.clock() - start_time >= duration_seconds then
                enabled = false

                atvdragao[enemy] = false
                drageffect[enemy] = 0
                return
            end

            local enemy_manager =
                sdk.get_managed_singleton("snow.enemy.EnemyManager")
            if not enemy_manager then return end

            local rate_data = enemy_manager:call(
                "getDifficultyAttackRateTableData(System.UInt16, System.Boolean)",
                difficulty_id,
                false
            )

            if not rate_data or not sdk.is_managed_object(rate_data) then
                return
            end
            if enemy and baseAtk[enemy] == nil then
                baseAtk[enemy] = rate_data:call("get_AttackRate")
            end
            local ataque = baseAtk[enemy]
            if attack_rate_value == false then
                rate_data:set_field("_AttackRate", ataque * 0.8 )
            else
                rate_data:set_field("_AttackRate", 0.0)
            end
        end,

        function(retval)
            return retval
        end
    )


    re.on_frame(function()
        if enabled then return end
        if not enemy then return end
        if not baseAtk[enemy] then return end

        local enemy_manager =
            sdk.get_managed_singleton("snow.enemy.EnemyManager")
        if not enemy_manager then return end

        local rate_data = enemy_manager:call(
            "getDifficultyAttackRateTableData(System.UInt16, System.Boolean)",
            difficulty_id,
            false
        )

        if rate_data and sdk.is_managed_object(rate_data) then
            rate_data:set_field("_AttackRate", baseAtk[enemy])
            
        end

        baseAtk[enemy] = nil
        enemy = nil
    end)

    
end

local function Hook_ShellBase_RequestDestroy_ByEmType(targetEmType, duration_sec)
    if targetEmType == nil then
        return
    end

    duration_sec = duration_sec or 0
    local start_time = os.clock()
    local active = true

    local ShellBase = sdk.find_type_definition("snow.shell.ShellBase")
    if not ShellBase then
        return
    end

    local method = ShellBase:get_method("requestHitAttackWithHitID", 4)
    if not method then
        return
    end

    sdk.hook(
        method,

        function(args)
            if not active then return end

            if duration_sec > 0 and (os.clock() - start_time) >= duration_sec then
                active = false
                return
            end

            local shell = sdk.to_managed_object(args[2])
            if not shell then return end

            -- Shell ID
            local ok_id, shellID = pcall(function()
                return shell:call("get_ID")
            end)
            if not ok_id or shellID == nil then return end

            -- OwnerObject
            local ok_owner, owner = pcall(function()
                return shell:call("get_OwnerObject")
            end)
            if not ok_owner or not owner then return end

            -- EnemyType
            local ok_et, ownerEmType = pcall(function()
                return owner:call("get_EnemyType")
            end)
            if not ok_et then return end

            -- Comparação direta
            if ownerEmType == targetEmType then
                pcall(function()
                    shell:set_field("_RequestDestroy", true)
                end)

                
            end
        end,

        function(retval)
            return retval
        end
    )

 
end

local function StartCondDragaoDecay(enemy)
    if not enemy or not sdk.is_managed_object(enemy) then return end

    if cond_dragao_active[enemy] then
        return
    end

    cond_dragao_active[enemy] = true
    cond_dragao_last_time[enemy] = os.clock()


    re.on_frame(function()
        if not cond_dragao_active[enemy] then
            return
        end

        -- enemy inválido
        if not enemy or not sdk.is_managed_object(enemy) then
            cond_dragao_active[enemy] = false
            return
        end

        if not cond_dragao[enemy] or cond_dragao[enemy] <= 0 then
            cond_dragao[enemy] = 0
            cond_dragao_active[enemy] = false
            return
        end

        local now = os.clock()
        local elapsed = now - cond_dragao_last_time[enemy]

        if elapsed >= 2.0 then
            cond_dragao_last_time[enemy] = now

            cond_dragao[enemy] = cond_dragao[enemy] - 1
            if cond_dragao[enemy] < 0 then
                cond_dragao[enemy] = 0
            end

           

            if cond_dragao[enemy] <= 0 then
                cond_dragao_active[enemy] = false
            end
        end
    end)
end




function InitPlayerDataScanner(enemy,hit_pos,crithit,eledmg1,eledmg2,eledmg3,eleType,attacker_type,element)
    local sdk = sdk
    local log_prefix = "[PlayerDataScanner] "
    if dragaoTime[enemy] == nil then iniciaDragon(enemy) end   
    local enabled = true
    local hp = enemy:call("getHpVital()")
    if hp == 0 then return end
            local chance = 0
            if  eleType == 7 and atvdragao[enemy] == false then        -- explosão principal
                if attacker_type == 0 then ganho = eledmg3 * 0.5 else ganho = eledmg3 end 
                if cond_dragao_active[enemy] ~= true then StartCondDragaoDecay(enemy) end
            else
                ganho = 0
            end

            if element > 50 and attacker_type == 0 then
                speed = 0.6
                color = color_map.Vescuro3
                if last_container then
                        schedule_effect(last_container, color,speed, 0.1)
                end
                SpawnEffectCustom(hit_pos, 0, 800, 0.3, "Black", 1.5)
                SpawnEffectCustom(hit_pos, 100, 1003, 0.3, "Black", 1.5)
                SpawnEffectCustom(hit_pos, 100, 160, 0.3, "DarkRed", 0.6)
                SpawnEffectCustom(hit_pos, 100, 1091, 0.2, "Black", 0.1)
                SpawnEffectCustom(hit_pos, 100, 1004, 0.11, "DkGray", 4.5)
                SpawnEffectCustom(hit_pos, 100, 355, 0.3, "Brown", 2.5)

                for i = 0, 3 do

                    SpawnEffectCustom(hit_pos, 100, 1004, 0.13, "DarkRed", 4.5)
                end
            elseif (element >= 35 and eledmg3 <=50) and attacker_type == 0 then
                speed = 0.7
                color = color_map.DarkRed
                if last_container then
                        schedule_effect(last_container, color,speed, 0.2)
                end
                --SpawnEffectCustom(hit_pos, 100, 354, 0.3, "DarkRed", 0.4)
                --SpawnEffectCustom(hit_pos, 100, 364, 0.4, "DarkRed", 0.4)
                --SpawnEffectCustom(hit_pos, 100, 370, 0.4, "DarkRed", 1.4)
            SpawnEffectCustom(hit_pos, 100, 1004, 0.13, "LtGray", 2.5)

                SpawnEffectCustom(hit_pos, 0, 800, 0.3, "Black", 1.5)
                SpawnEffectCustom(hit_pos, 100, 1003, 0.3, "Black", 1.5)
                SpawnEffectCustom(hit_pos, 100, 1003, 0.3, "Black", 1.5)
                

            else  SpawnEffectCustom(hit_pos, 100, 1004, 0.14, "White", 2.5) end

            if dragaoTime[enemy] == nil then return end
            if ganho > 0 then
                cond_dragao[enemy] = cond_dragao[enemy] + ganho
            end

            

            if crithit == 1 and drageffect[enemy] == 1 and element > 50 and attacker_type == 0 then
                color = Red
                speed = 0.4
                
                if last_container then
                    schedule_effect(last_container, color,speed, 0.3)
                end
                SpawnEffectCustom(hit_pos, 200, 1020, nil, "Red", 3.0)
                SpawnEffectCustom(hit_pos, 0, 1000, nil, "LightPink", 3.0)
                SpawnEffectCustom(hit_pos, 100, 800, nil, "Red", 3.0)
                CriarHookElemental()

            end


            if cond_dragao[enemy] >= dragao[enemy] and drageffect[enemy] == 0 then
                cond_dragao_active[enemy] = false
                cond_dragao[enemy] = cond_dragao[enemy] - dragao[enemy]  -- reseta o acumulador (mantém sobra)
                local no =    enemy:call("getNandoTblNo(snow.enemy.EnemyDef.NandoKind)",1)
                atvdragao[enemy] = true
                local typeE = enemy:call("get_EnemyType()")
                HookEnemyManagerAttackRateTimed(no, false,enemy,dragaoTime[enemy])
                if addDragao[enemy] ~= nil then  dragao[enemy] = dragao[enemy] + addDragao[enemy] end

                if element > 50 and attacker_type == 0 then
                    if SpawnConditionVisual then
                        SpawnConditionVisual(enemy, 0, "Vescuro3", 0.1, 0.5,false,dragaoTime[enemy])
                        SpawnConditionVisual(enemy, 0, "LPink3", 0.1, 0.5,false,dragaoTime[enemy])
                        SpawnConditionVisual(enemy, 6, "Crimson", 0.1, 0.5,false,dragaoTime[enemy])
                        Hook_ShellBase_RequestDestroy_ByEmType(typeE, dragaoTime[enemy])


                        drageffect[enemy] = 1

                    end
                elseif (element >=35 and element <= 50 ) and attacker_type == 0 then
                    if SpawnConditionVisual then
                        SpawnConditionVisual(enemy, 0, "Vescuro3", 0.1, 0.5,false,dragaoTime[enemy])
                        Hook_ShellBase_RequestDestroy_ByEmType(typeE, dragaoTime[enemy])

                    end
                    
                else
                    SpawnConditionVisual(enemy, 0, "Crimson", 0.1, 0.5,false,dragaoTime[enemy])

                end
            end

end

local function extract_no_value(entry)
    if type(entry) ~= "table" then
        return nil
    end

    if type(entry.value) ~= "number" then
        return nil
    end

    return entry.value
end


-- Delay seguro usando on_frame
local function delay(seconds, callback)
    if type(callback) ~= "function" then
        return
    end

    local start = os.clock()

    local function wrapped()
        local ok, result = pcall(function()
            if os.clock() - start >= seconds then
                callback()
                return false -- remove callback do on_frame
            end
        end)

        if not ok then
            return false -- remover mesmo assim
        end

        return result
    end

    re.on_frame(wrapped)
end



local function make_real_stock(dmg_type, raw_dmg)
    local T = sdk.find_type_definition("snow.enemy.EnemyDamageStockParam")
    local stk = T:create_instance()

    stk:set_field("<DamageType>k__BackingField", dmg_type or 0)  -- 0=cut,1=impact,2=shot
    stk:set_field("<Damage>k__BackingField", raw_dmg or 30.0)
    stk:set_field("<IsHitDamage>k__BackingField", true)
    stk:set_field("<IsValid>k__BackingField", true)

    return stk
end


local function make_action_attr()
    local T = sdk.find_type_definition("snow.enemy.EnemyDef.DamageActionAttr")
    return T:create_instance()
end



