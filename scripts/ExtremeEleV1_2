local EFFECT_ACTIVE_DURATION = dragaoTime[enemy] or 25.0
local effect_last_activation = 0
local hit_hook_installed = false

-- tabela: HitID → dados originais
local original_hit_data = {}

function ActivateZeroDamageEffect()
    effect_last_activation = os.clock()
end

function IsEffectActive()
    return (os.clock() - effect_last_activation) <= EFFECT_ACTIVE_DURATION
end



function RestoreOriginalDamage(this, hit_id)
    local backup = original_hit_data[hit_id]
    if not backup then return end

    -- campos restaurados
    if backup.Damage then this:set_field("<Damage>k__BackingField", backup.Damage) end
    if backup.BaseDamage then this:set_field("_BaseDamage", backup.BaseDamage) end
    if backup.Power then this:set_field("_Power", backup.Power) end
    if backup.Element then this:set_field("_BaseAttackElementValue", backup.Element) end
    if backup.Debuff then this:set_field("_BaseDebuffValue", backup.Debuff) end

end



function InstallBaseHitHook()
    if hit_hook_installed then return end
    hit_hook_installed = true

    local Type = sdk.find_type_definition("snow.hit.userdata.BaseHitAttackRSData")
    if not Type then
        return
    end

    local method_init = Type:get_method("init")
    if not method_init then
        return
    end
    local debuffType = Type:get_field("<DamageTypeValue>k__BackingField")
    local f_Damage = Type:get_field("<Damage>k__BackingField")
    local f_BaseDamage = Type:get_field("_BaseDamage")
    local f_Power = Type:get_field("_Power")
    local f_Element = Type:get_field("_BaseAttackElementValue")
    local f_Debuff = Type:get_field("_BaseDebuffValue")
    local f_HitID = Type:get_field("<HitID>k__BackingField")


    sdk.hook(
        method_init,

       
        function(args)
            local this = sdk.to_managed_object(args[2])
            if this == nil then return args end

            local hit_id = nil
            if f_HitID then hit_id = this:get_field("<HitID>k__BackingField") end
            if not hit_id then return args end

        
            if not original_hit_data[hit_id] then
                original_hit_data[hit_id] = {
                    Type    = DamageType and this:get_field("<DamageTypeValue>k__BackingField") or nil,
                    Damage  = f_Damage and this:get_field("<Damage>k__BackingField") or nil,
                    BaseDamage = f_BaseDamage and this:get_field("_BaseDamage") or nil,
                    Power   = f_Power and this:get_field("_Power") or nil,
                    Element = f_Element and this:get_field("_BaseAttackElementValue") or nil,
                    Debuff  = f_Debuff and this:get_field("_BaseDebuffValue") or nil,
                }
            end


            if not IsEffectActive() then
                RestoreOriginalDamage(this, hit_id)
                return args
            end

   
            local backup = original_hit_data[hit_id]
            if backup then
                if f_Damage and backup.Damage then
                    this:set_field("<Damage>k__BackingField", backup.Damage * 0.8)
                end

                if f_BaseDamage and backup.BaseDamage then
                    this:set_field("_BaseDamage", backup.BaseDamage * 0.8)
                end

                if f_Power and backup.Power then
                    this:set_field("_Power", backup.Power * 0.8)
                end

                if f_Element and backup.Element then
                    this:set_field("_BaseAttackElementValue", backup.Element * 0.0)
                end

                if f_Debuff and backup.Debuff then
                    this:set_field("_BaseDebuffValue", backup.Debuff * 0.0)
                end
            end


            return args
        end,


        function(retval)
            return retval
        end
    )
end



