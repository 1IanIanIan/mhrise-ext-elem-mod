local function spawn_and_paint_effect(effect_str, color_name, delay, speed)
    local container_str, element_str = effect_str:match("(%d+)|(%d+)")
    if not container_str or not element_str then
        return nil
    end

    local container_id = tonumber(container_str)
    local element_id   = tonumber(element_str)

    local user = sdk.get_managed_singleton("snow.player.PlayerManager")
    if not user then return nil end
    local master_player = user:call("findMasterPlayer")
    if not master_player then return nil end
    local userObject = master_player:call("get_GameObject")
    if not userObject then return nil end

    local effectManager = userObject:call(
        "getComponent(System.Type)",
        sdk.typeof("via.effect.script.ObjectEffectManager")
    )
    if not effectManager then return nil end

    -- cria EffectID
    local effectID = sdk.create_instance("via.effect.script.EffectID", true):add_ref()
    effectID.ContainerID = container_id
    effectID.ElementID   = element_id

    -- overload mais seguro
    local requestEffect = sdk.find_type_definition("via.effect.script.ObjectEffectManager")
        :get_method("requestEffect(via.effect.script.EffectID, via.GameObject, System.Int32, via.effect.script.EffectManager.WwiseTriggerInfo)")

    local created = nil
    if requestEffect then
        created = requestEffect:call(effectManager, effectID, userObject, 0, nil)
    end

    if created then
        local color = color_map[color_name]
        if color and schedule_effect then
            schedule_effect(created, color, speed or 1.0, delay or 0.0)
        end
        return created
    else
        return nil
    end
end






local last_blast_count = {}

function BlastAtivado(enemy)
    if not enemy then return false end

    local damage_param = enemy:call("get_DamageParam")
    if not damage_param then return false end

    local blast_param = damage_param:get_field("_BlastParam")
    if not blast_param then return false end

    local activate_count_arr = blast_param:call("get_ActivateCount")
    if not activate_count_arr then return false end

    local ok, val = pcall(function() return activate_count_arr:call("GetValue(System.Int32)", 0) end)
    if not ok or not val then return false end

    local field = val:get_type_definition():get_field("mValue")
    if not field then return false end

    local count = field:get_data(val)
    if not count then return false end

    local key = tostring(enemy:get_field("<UniqueId>k__BackingField") or tostring(enemy))
    local last = last_blast_count[key] or 0

    if count > last then
        last_blast_count[key] = count
        return true
    end

    local damage_param = enemy:call("get_DamageParam")
                
    local blast_param = damage_param:get_field("_BlastParam")
    local rate = blast_param:call("get_BlastDamageAdjustRateByEnemyLv")

    bldmg = blast_param:call("get_BlastDamage")

    blast_param:call("set_BlastDamage(System.Single)",(bldmg + 50.00))

    last_blast_count[key] = count
    return false
end


local function modify_effect(container, color, speed)
    if not container or not sdk.is_managed_object(container) then
        return
    end
    if not color then
        return
    end

    local tdef = container:get_type_definition()
    if not tdef then
        return
    end


    if not _G.__hook_set_position_installed then
        _G.__hook_set_position_installed = true

        local pos_info_tdef =
            sdk.find_type_definition("via.effect.script.EffectPositionHolder.PositionInfo")

        if pos_info_tdef then
            local set_pos_method =
                pos_info_tdef:get_method("set_position(via.vec3)")

            if set_pos_method then
                sdk.hook(
                    set_pos_method,
                    function(args)
                        

                        local self = sdk.to_managed_object(args[2])
                        local pos  = args[3]

                        if not self or not pos then
                            return
                        end

                        local ok, vec = pcall(sdk.to_valuetype, pos)
                        if not ok or not vec then
                            return
                        end

                        local vec_tdef = vec:get_type_definition()
                        if not vec_tdef then
                            return
                        end
                        if vec_tdef:get_full_name() ~= "via.vec3" then
                            return
                        end

                        local okx, x = pcall(vec.get_field, vec, "x")
                        local oky, y = pcall(vec.get_field, vec, "y")
                        local okz, z = pcall(vec.get_field, vec, "z")

                        if not (okx and oky and okz) then
                            return
                        end

                       
                    end,
                    function(retval)
                        return retval
                    end
                )

            end
        end
    end


    local set_root_color = tdef:get_method("setRootColor(via.Color)")
    if set_root_color then
        pcall(function()
            container:call("setRootColor(via.Color)", color)
        end)
    end


    if speed then
        local set_speed = tdef:get_method("setPlaySpeed(System.Single)")
        if set_speed then
            pcall(function()
                container:call("setPlaySpeed(System.Single)", speed)
            end)
        else
            pcall(function()
                container:set_field("_speed", speed)
            end)
        end
    end
end



local function dump_color(label, c)
    if not c then
        return
    end

    local function safe_get(method)
        local ok, val = pcall(function() return c:call(method) end)
        if ok and val ~= nil then
            return tostring(val)
        else
            return "ERR"
        end
    end

    local ttype = "ERR"
    local ok_t, tdef = pcall(function() return sdk.typeof(c) end)
    if ok_t and tdef then
        ttype = tostring(tdef)
    end


end

local function multiply_colors(colorA, colorB)

    if not colorA or not colorB then
        return nil
    end

    dump_color("colorA", colorA)
    dump_color("colorB", colorB)

    local tdef = sdk.find_type_definition("via.Color")
    local op_mul = tdef:get_method("op_Multiply(via.Color, via.Color)")

    local ok, newColor = pcall(function()
        return op_mul:call(nil, colorA, colorB)
    end)

    if not ok or not newColor then
        return nil
    end

    dump_color("Resultado", newColor)
    return newColor
end

local function add_colors(colorA, colorB)

    if not colorA or not colorB then
        return nil
    end

    dump_color("colorA", colorA)
    dump_color("colorB", colorB)

    local tdef = sdk.find_type_definition("via.Color")
    local op_add = tdef:get_method("op_Addition(via.Color, via.Color)")

    local ok, newColor = pcall(function()
        return op_add:call(nil, colorA, colorB)
    end)

    if not ok or not newColor then
        return nil
    end

    dump_color("Resultado", newColor)
    return newColor
end


local LThunder = add_colors(color_map.Orange,color_map.DarkOrange)
if LThunder then
    color_map.LThunder = LThunder  

end

local LFire = multiply_colors(color_map.DarkGreen, color_map.Brown)
if LFire then
    color_map.LFire = LFire  

end


