local function check_and_restore_sharpness()
    local player_manager = sdk.get_managed_singleton("snow.player.PlayerManager")
    if not player_manager then
        return
    end

    local master_player = player_manager:call("findMasterPlayer")
    if not master_player then
        return
    end

    local player_base = master_player

    local sharp_max = player_base:call("get_SharpnessGaugeMax")
    local sharp_current = player_base:call("get_SharpnessGauge")
    if not sharp_max or not sharp_current then
        return
    end

 
        local restore_amount = math.floor(sharp_max * 0.05) -- 5%
        local new_value = math.min(sharp_current + restore_amount, sharp_max)
        spawn_and_paint_effect("0|999", "Yellow", 0.1, 0.5)

        player_base:call("set_SharpnessGauge(System.Int32)", new_value)
     
end

local function replicate_last_container(repeats, delay_step, speed)
    if not last_container then
        return
    end

    repeats = repeats or 5
    delay_step = delay_step or 0.5
    speed = speed or 1.0

    local color_cycle = {
        color_map.Brown,
        color_map.Red,
        color_map.Blue,
        color_map.Green,
        color_map.Pink,
        color_map.Cyan,
        color_map.White,
        color_map.RoyalBlue,
        color_map.SkyBlue
    }

    for i = 1, repeats do
        local color = color_cycle[((i - 1) % #color_cycle) + 1]
        local delay = i * delay_step
        schedule_effect(last_container, color, speed, delay)
    
    end
end

local function dump_positions_from_container(container)
    if not container then
        return
    end

    local tdef = container:get_type_definition()
    if not tdef then
        return
    end

    local get_positions = tdef:get_method("get_effectPositions")
    if not get_positions then
        return
    end

    -- chama o método
    local ok, enumerable = pcall(function() return get_positions:call(container) end)
    if not ok or not enumerable then
        return
    end

    local enumerator = enumerable:call("GetEnumerator")
    if not enumerator then
        return
    end

    local i = 0
    while enumerator:call("MoveNext") do
        local pos_info = enumerator:call("get_Current")
        if pos_info then
            local pos = pos_info:call("get_position")
            local startPos = pos_info:call("get_startPosition")

            local px, py, pz = 0, 0, 0
            local sx, sy, sz = 0, 0, 0

            if pos then
                px, py, pz = pos.x, pos.y, pos.z
            end
            if startPos then
                sx, sy, sz = startPos.x, startPos.y, startPos.z
            end


        else
            return
        end
        i = i + 1
    end

    if i == 0 then
        return
    end
end

local function clean_old_hits()
    local now = get_time()
    for i = #recent_hits, 1, -1 do
        if now - recent_hits[i].time > HIT_BUFFER_TIME then
            table.remove(recent_hits, i)
        end
    end
end

local function get_monster_name(enemy)
    if not enemy then return "Desconhecido" end
    if not get_name_message_method then return "Desconhecido" end
    local name_msg = get_name_message_method:call(enemy)
    if name_msg then return name_msg:call("ToString") or "Desconhecido" end
    return "Desconhecido"
end

