local start_condition_method = enemy_character_base_type_def:get_method("startConditionDamageEffect")
sdk.hook(start_condition_method,
    function(args)
        local enemy = sdk.to_managed_object(args[2])
        local status_id = sdk.to_int64(args[3])
        
        if status_id == 0 and enemy then
            local now = get_time()
            clean_old_hits()

            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                    

                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                    end

                    table.remove(recent_hits, i)
                    break
                end
            end
        end

        if status_id == 4 and enemy then
            local now = get_time()
            clean_old_hits()

            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                  
                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                    end

                    table.remove(recent_hits, i)
                    break
                end
            end
        end

        if status_id == 8 and enemy then
            local now = get_time()
            clean_old_hits()

            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                  
                    SpawnConditionVisual(enemy, 8, "SeaGreen", 0.1, 0.3, false, 20.5)

                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                    end
                    table.remove(recent_hits, i)
                    break
                end
            end
        end
        if status_id == 6 and enemy then
            local now = get_time()
            clean_old_hits()

            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                   

                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                    end

                    table.remove(recent_hits, i)
                    break
                end
            end
        end
        if status_id == 9 and enemy then
            local now = get_time()
            clean_old_hits()

            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                   

                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                    end

                    table.remove(recent_hits, i)
                    break
                end
            end
        end
        if status_id == 7 and enemy then
            local now = get_time()
            clean_old_hits()

                
            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                    
                    
                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                       
                    end

                    table.remove(recent_hits, i)
                    break
                end
            end
        end
        local damage_param = enemy:call("get_DamageParam")
        if not damage_param then return end

        local blast_param = damage_param:get_field("_BlastParam")
        if not blast_param then return end

        local ativo = blast_param:call("get_IsActive") 

        if ativo then
            local now = get_time()
            clean_old_hits()

            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                  

                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                    end

                    table.remove(recent_hits, i)
                    break
                end
            end
        end

        if status_id == 1 and enemy then
            local now = get_time()
            clean_old_hits()

            for i, hit in ipairs(recent_hits) do
                if hit.enemy == enemy and (now - hit.time) <= HIT_BUFFER_TIME then
                    

                    if hit.simple_category then
                        _G.onVenomHitDetected(hit.simple_category, hit.damage, hit.time, hit.monster_name, hit.monster_size, hit.enemy)
                    end

                    table.remove(recent_hits, i)
                    break
                end
            end
        end

    end,
    function(retval) return retval end
)

sdk.hook(enemy_character_base_type_def:get_method("update"),
    function(args) 
        process_scheduled_effects()
    end,
    function(retval)
        return retval
    end
)
