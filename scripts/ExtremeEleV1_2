    color_map.LFire3 = LFire3  

end


local LPink = multiply_colors(color_map.DarkRed, color_map.DarkRed)
if LPink then
    color_map.LPink = LPink  

end

local LPink3 = multiply_colors(color_map.LPink, color_map.LPink)
if LPink3 then
    color_map.LPink3 = LPink3  

end



