function InstallStockDamageModifier(config)
    config = config or {}
    config.enabled = (config.enabled ~= false)
    config.pending = nil

    local enemy_character_base_type_def =
        sdk.find_type_definition("snow.enemy.EnemyCharacterBase")
    local stock_damage_method =
        enemy_character_base_type_def:get_method("stockDamage")

    sdk.hook(
        stock_damage_method,
        function(args)
            if not config.enabled then return end
            if not config.pending then return end

            local damage = sdk.to_managed_object(args[3])
            if not damage then return end


            local ok, err = pcall(function()
                damage:call("set_IsConditionDamage", true)
                damage:call("set_IsStatusDamage", true)

                if config.pending.cond_type then
                    damage:call("set_ConditionDamageType", config.pending.cond_type)
                end
                if config.pending.cond_value then
                    damage:call("set_ConditionDamage", config.pending.cond_value)
                end

                if config.pending.cond_type2 then
                    damage:call(
                        "set_ConditionDamageType2(snow.enemy.EnemyDef.ConditionDamageType)",
                        config.pending.cond_type2
                    )
                end
                if config.pending.cond_value2 then
                    damage:call("set_ConditionDamage2", config.pending.cond_value2)
                end

                if config.pending.cond_type3 then
                    damage:call("set_ConditionDamageType3", config.pending.cond_type3)
                end
                if config.pending.cond_value3 then
                    damage:call("set_ConditionDamage3", config.pending.cond_value3)
                end

                if config.pending.element_type then
                    damage:call("set_ElementType", config.pending.element_type)
                end
                if config.pending.element_value then
                    damage:call("set_ElementDamage", config.pending.element_value)
                end

                if config.pending.stamina_value then
                    damage:call("set_StaminaDamage", config.pending.stamina_value)
                end
                if config.pending.stun_value then
                    damage:call("set_StunDamage", config.pending.stun_value)
                end
            end)

            

            config.pending = nil
        end
    )

 
    local function start_expire_timer()
        local start_time = os.clock()
        local frame_handle

        frame_handle = re.on_frame(function()
            if os.clock() - start_time >= 1.0 then
                config.enabled = false
                config.pending = nil


                if frame_handle then
                    re.remove_event_listener(frame_handle)
                    frame_handle = nil
                end
            end
        end)
    end

   
    return function(params)
        config.enabled = true
        config.pending = params
        start_expire_timer()
    end
end

local sdk = sdk   

local function create_single_array(values)
    local Single = sdk.find_type_definition("System.Single")
    if not Single then
        return nil
    end
    
    local arr = sdk.create_managed_array(Single, #values)
    if not arr then
        return nil
    end

    for i = 1, #values do
        arr[i-1] = values[i]
    end

    return arr
end


local patch_ativo = false
local patch_fim = 0
local patch_target = nil
local patch_values = {}

function start_condition_patch(damageParam, seconds, values)
    patch_ativo = true
    patch_fim = os.clock() + seconds
    patch_target = damageParam
    patch_values = values

end


re.on_frame(function(dt)
    if not patch_ativo then return end

    if os.clock() >= patch_fim then
        patch_ativo = false
        return
    end

    if not patch_target then return end

    local list = patch_target:get_field("<DamageStock>k__BackingField")
    if not list then return end

    local count = list:call("get_Count")
    for i = 0, count - 1 do
        local stock = list:call("get_Item", i)
        if stock then

            local arr = stock:get_field("<ConditionDamage>k__BackingField")
            if arr then
                local len = arr:call("get_Length")

                for j = 0, len - 1 do
                    if patch_values[j+1] ~= nil then
                        arr[j] = patch_values[j+1]
                    end
                end

                stock:call("set_ConditionDamage", arr)
            end
        end
    end
end)




