local pending_deactivates = {}

function schedule_deactivate(enemy, param, delay)
    pending_deactivates[enemy] = {
        param = param,
        time  = os.clock() + (delay or 0.5)
    }
end

re.on_frame(function()
    for enemy, data in pairs(pending_deactivates) do
        if os.clock() >= data.time then
            local pa_param = data.param
            if pa_param then
                pcall(function()
                    pa_param:call("deactivate")
                end)
            end
            pending_deactivates[enemy] = nil
        end
    end
end)

local scheduled_effects = {}

local function get_time() return os.clock() end

local function schedule_effect(container, color, speed,delay)
    table.insert(scheduled_effects, {container = container, color = color,speed = speed, apply_time = get_time() + delay})
end

local function process_scheduled_effects()
    local now = get_time()
    for i = #scheduled_effects, 1, -1 do
        local effect = scheduled_effects[i]
        if now >= effect.apply_time then
            modify_effect(effect.container, effect.color,effect.speed)
            table.remove(scheduled_effects, i)
        end
    end
end

local last_container = nil
local created_effect_container_type = sdk.find_type_definition("via.effect.script.CreatedEffectContainer")
local getAllPlayers_method = created_effect_container_type:get_method("getAllPlayers")

sdk.hook(getAllPlayers_method,
    function(args)
        local container = sdk.to_managed_object(args[2])
        if not container then return end

        last_container = container

    
    end,
    function(retval)
        return retval
    end
)



function SpawnEffectOnPlayer_Visual(
    containerID,
    elementID,
    color_name,
    delay,
    speed,
    disable_effect,
    duration
)
    -- PlayerManager
    local pm = sdk.get_managed_singleton("snow.player.PlayerManager")
    if not pm then
        return nil
    end

    local player = pm:findMasterPlayer()
    if not player then
        return nil
    end

    -- GameObject do player
    local playerObj = player:get_GameObject()
    if not playerObj then
        return nil
    end

    -- Cria EffectID
    local effectID = sdk.create_instance("via.effect.script.EffectID", true):add_ref()
    effectID.ContainerID = containerID
    effectID.ElementID   = elementID

    -- ObjectEffectManager do player
    local effectManager = playerObj:call(
        "getComponent(System.Type)",
        sdk.typeof("via.effect.script.ObjectEffectManager")
    )
    if not effectManager then
        return nil
    end

    -- requestEffectInternal (segue o player)
    local req = sdk.find_type_definition("via.effect.script.ObjectEffectManager")
        :get_method("requestEffectInternal(via.effect.script.EffectID, via.GameObject, System.Int32, via.effect.script.EffectManager.WwiseTriggerInfo, via.effect.script.EffectManager.RequestOverwriteParam)")

    if not req then
        return nil
    end

    local created = req(effectManager, effectID, nil, nil, nil, nil)
    if not created then
        return nil
    end

   

    -- Desativa imediatamente (se pedido)
    if disable_effect then
        if created.finishAll then created:finishAll() end
        if created.finishAllInternal then created:finishAllInternal() end
        return nil
    end


    if duration and duration > 0 then
        local start_time = os.clock()
        local expired = false
        local frame_handle

        frame_handle = re.on_frame(function()
            if expired or not created or not sdk.is_managed_object(created) then
                if frame_handle then
                    re.remove_event_listener(frame_handle)
                    frame_handle = nil
                end
                return
            end

            if os.clock() - start_time >= duration then
                expired = true
                pcall(function()
                    if created.finishAll then created:finishAll() end
                    if created.finishAllInternal then created:finishAllInternal() end
                end)

                if frame_handle then
                    re.remove_event_listener(frame_handle)
                    frame_handle = nil
                end
            end
        end)
    end


    if color_name and schedule_effect then
        local color = color_map[color_name]
        if color then
            schedule_effect(
                created,
                color,
                speed or 1.0,
                delay or 0.0
            )
        end
    end

    return created
end

function SpawnConditionVisual(enemy, cond_type, color_name, delay, speed, disable_effect, duration)
    if not enemy then
        return nil
    end

    local id = enemy:call("getConditionDamageEffectId(snow.enemy.EnemyDef.ConditionDamageEffectType)", cond_type)
    if not id then
        return nil
    end

    local contid = id:call("get_containerID")
    local elementid = id:call("get_elementID")
  

    -- Cria EffectID
    local effectID = sdk.create_instance("via.effect.script.EffectID", true):add_ref()
    effectID.ContainerID = contid
    effectID.ElementID   = elementid

    -- GameObject do inimigo
    local enemyObj = enemy:call("get_GameObject")
    if not enemyObj then
        return nil
    end

    local effectManager = enemyObj:call(
        "getComponent(System.Type)",
        sdk.typeof("via.effect.script.ObjectEffectManager")
    )
    if not effectManager then
        return nil
    end

    -- Método de requestEffect
    local req = sdk.find_type_definition("via.effect.script.ObjectEffectManager")
        :get_method("requestEffect(via.effect.script.EffectID, via.GameObject, System.Int32, via.effect.script.EffectManager.WwiseTriggerInfo)")

    local created = req:call(effectManager, effectID, enemyObj, 0, nil)
    if not created then
        return nil
    end


    -- Se disable_effect for true → desativa imediatamente
    if disable_effect then
        if created.finishAll then created:finishAll() end
        if created.finishAllInternal then created:finishAllInternal() end
        return nil
    end


    if duration and duration > 0 then
        local start_time = os.clock()
        local expired = false
        local frame_handle

        frame_handle = re.on_frame(function()
            -- Se já expirou ou foi coletado, remove
            if expired or not created or not sdk.is_managed_object(created) then
                if frame_handle then
                    re.remove_event_listener(frame_handle)
                    frame_handle = nil
                end
                return
            end

            local elapsed = os.clock() - start_time
            if elapsed >= duration then
                expired = true

                -- Protege contra métodos inexistentes
                if created and sdk.is_managed_object(created) then
                    pcall(function()
                        if created.finishAll then created:finishAll() end
                        if created.finishAllInternal then created:finishAllInternal() end
                    end)


                end

                -- Remove o callback deste loop
                if frame_handle then
                    re.remove_event_listener(frame_handle)
                    frame_handle = nil
                end
            end
        end)
    end

    if color_name and schedule_effect then
        local color = color_map[color_name]
        if color then
            schedule_effect(created, color, speed or 1.0, delay or 0.0)
        end
    end

    return created
end



function inspectObject(obj, tag)
    if not obj then
        return
    end

    local tdef = obj:get_type_definition()
    if not tdef then
        return
    end



   
    for _, m in ipairs(tdef:get_methods()) do
        local name = m:get_name()
        if name:find("^get_") then
            local ok, value = pcall(function()
                return obj:call(name)
            end)
        end
    end


    for _, f in ipairs(tdef:get_fields()) do
        local fname = f:get_name()
        local ok, value = pcall(function()
            return f:get_data(obj)
        end)
    end


    local important = "<DamageRate>k__BackingField"

    local field = tdef:get_field(important)
    if field then
        local ok, val = pcall(function()
            return field:get_data(obj)
        end)
    else
    end

end

