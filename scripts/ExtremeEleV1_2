local tempo_fim = 0
local ultimo_print = 0

-- Configuração global do buff
local stacks_global = 5
local bonus_global = 5
local duracao_global = 5

-- Função segura de print
local function sprint(...) pcall(print, ...) end

-- Função para obter PlayerQuestBase
local function get_player_questbase()
    local pm = sdk.get_managed_singleton("snow.player.PlayerManager")
    if not pm then return nil end
    local master = pm:call("findMasterPlayer")
    if not master then return nil end
    local ok, pq = pcall(function() return sdk.to_managed_object(master) end)
    if ok and pq then return pq end
    return nil
end

-- Hook permanente no método update
local tdef = sdk.find_type_definition("snow.player.PlayerQuestBase")
if not tdef then
    return
end

local update_method = tdef:get_method("update")
if not update_method then
    return
end

local enabled = true
sdk.hook(
    update_method,
    function(args)
        if not enabled then return end
        local pq = get_player_questbase()
        if not pq then return end
        if not buff_ativo then return end

        local ok = pcall(function()
            if forte_ativo then
                pq:call("setCritChanceUpBow", 10, 5.0)
                pq:call("setAtkUpBuffSecond", 10, 5.0)
              
                
            else    
                pq:call("setCritChanceUpBow", 5, 5.0)
                pq:call("setAtkUpBuffSecond", 5, 5.0)
            end    
        end)
    end,
    function(retval) return retval end
)

re.on_frame(function()
    if buff_ativo then
        local agora = os.clock()

        if agora - ultimo_print >= 1 then
            ultimo_print = agora
            local restante = math.max(0, tempo_fim - agora)
            if forte_ativo then
                 SpawnEffectOnPlayer_Visual(
                    100,--containerID,
                    1002,--elementID,
                    "AstGreen",--color_name,
                    0,--delay,
                    1.0,--speed,
                    false,--disable_effect,
                    nil--duration

                )

            else    
                SpawnEffectOnPlayer_Visual(
                    100,--containerID,
                    1002,--elementID,
                    "tentativaMarelo",--color_name,
                    0,--delay,
                    1.0,--speed,
                    false,--disable_effect,
                    nil--duration

                )
            end    
        end

        if agora >= tempo_fim then
            buff_ativo = false
        end
    end
end)

local function aplicar_crit_boost(stacks, bonus, duracao,forte)
    stacks_global = stacks or stacks_global
    bonus_global = bonus or bonus_global
    duracao_global = duracao or duracao_global
    forte_ativo = forte   

    buff_ativo = true
    tempo_fim = os.clock() + duracao_global
    ultimo_print = os.clock() 
end


local function read_int32_array(a)
    if not a then return nil end

    local t = {}
    local len = a:call("get_Length")

    for i = 0, len - 1 do
        local elem = a:get_element(i)
        t[i] = elem and elem:get_field("mValue") or 0
    end

    return t
end


-- cache global
lastBlastCount = lastBlastCount or {}

local system_array = sdk.find_type_definition("System.Array")
local get_length = system_array:get_method("get_Length")
local get_value  = system_array:get_method("GetValue(System.Int32)")

local int32_type = sdk.find_type_definition("System.Int32")
local int32_value = int32_type:get_field("mValue")

function CheckBlast(enemy, hit_pos)
    if not enemy then return end

    local dmg = enemy:call("get_DamageParam")
    if not dmg then return end

    local blast = dmg:get_field("_BlastParam")
    if not blast then return end

    local actArr = blast:call("get_ActivateCount()")
    if not actArr then return end

    -- segurança
    local len = get_length:call(actArr)
    if not len or len == 0 then return end

    -- pegar System.Int32
    local valType = get_value:call(actArr, 0)
    if not valType then return end

    local count = int32_value:get_data(valType)

    -- comparação correta
    local last = lastBlastCount[enemy]
    if last == nil then
        lastBlastCount[enemy] = count
        return
    end

    if count > last then
        -- BLAST acabou de ocorrer (frame seguinte ao hit)
        SpawnEffectCustom(hit_pos, 200, 1011, 1.5, "White", 1.0)
    end

    lastBlastCount[enemy] = count
end

local system_array = sdk.find_type_definition("System.Array")
local get_length = system_array:get_method("get_Length")
local get_value  = system_array:get_method("GetValue(System.Int32)")

local single_type = sdk.find_type_definition("System.Single")
local single_value = single_type:get_field("mValue")

function LerBlastCount(enemy)
    if not enemy then return nil end

    local dmg_param = enemy:call("get_DamageParam")
    if not dmg_param then return nil end

    local blast_param = dmg_param:get_field("_BlastParam")
    if not blast_param then return nil end

    local stock_arr = blast_param:call("get_Stock()")
    if not stock_arr then return nil end

    local len = get_length:call(stock_arr)
    if not len or len == 0 then return nil end

    local valtype = get_value:call(stock_arr, 0)
    if not valtype then return nil end

    local stock_value = single_value:get_data(valtype)

    return stock_value   
end


function LerAguaCount(enemy)
    if not enemy then return nil end

    local dmg_param = enemy:call("get_DamageParam")
    if not dmg_param then return nil end

    local blast_param = dmg_param:get_field("_WaterParam")
    if not blast_param then return nil end

    local stock_arr = blast_param:call("get_Stock()")
    if not stock_arr then return nil end

    local len = get_length:call(stock_arr)
    if not len or len == 0 then return nil end

    local valtype = get_value:call(stock_arr, 0)
    if not valtype then return nil end

    local stock_value = single_value:get_data(valtype)

    return stock_value   
end


local system_array_type = sdk.find_type_definition("System.Array")
local set_value_method =
    system_array_type:get_method("SetValue(System.Object,System.Int32)")


local function set_array_value(arr, index, value)
    sdk.call_object_func(
        arr,
        "SetValue(System.Object,System.Int32)",
        value,
        index
    )
end

local timers = {}

local function start_timer(seconds, on_finish, enemy)
    local id = {}

    timers[id] = {
        start = os.clock(),
        duration = seconds,
        callback = on_finish,
        enemy = enemy
    }

    return id
end
re.on_frame(function()
    local now = os.clock()

    for id, t in pairs(timers) do
        if now - t.start >= t.duration then
            -- executa callback
            if t.callback then
                t.callback(t.enemy)
            end

            -- remove timer
            timers[id] = nil
        end
    end
end)




local function restore_addlimitAndTimer(enemy, paralyze_param)
    if not enemy or not sdk.is_managed_object(enemy) then return false end
    if not paralyze_param or not sdk.is_managed_object(paralyze_param) then return false end
    if not addL or not addL[enemy] then
        return false
    end
    paralyze_param:call("set_ActiveTime(System.Single)",timeP[enemy])
    contPA[enemy] = false


    local old = paralyze_param:call("get_AddLimit")
    if not old then
        return false
    end

    local len = old:get_Length()
    if len <= 0 then return false end

    local arr = sdk.create_managed_array("System.Single", len)

    for i = 0, len - 1 do
        local v = addL[enemy][i]

        if type(v) ~= "number" or v ~= v or v == math.huge or v == -math.huge then
            v = tonumber(old[i]) or 0.0
        end

        arr[i] = v
    end

    paralyze_param:call("set_AddLimit(System.Single[])", arr)

    

    -- limpa para não repetir
    addL[enemy] = nil

    return true
end


function ResetaBlast(enemy, Add)
    if not enemy then return end

    local dmg_param = enemy:call("get_DamageParam")
    if not dmg_param then return end

    local blast_param = dmg_param:get_field("_BlastParam")
    if not blast_param then return end

    -- Restaurar dano
    if BlastDmg[enemy] ~= nil then
        blast_param:call(
            "set_BlastDamage(System.Single)",
            BlastDmg[enemy]
        )
    end

    if not Add then return end

    -- AddLimit (System.Single[])
    local old = blast_param:call("get_AddLimit()")
    if not old then return end

    local len = sdk.call_object_func(old, "get_Length")
    if not len then return end

    local arr = sdk.create_managed_array("System.Single", len)

    for i = 0, len - 1 do
        local v = addB[enemy] and addB[enemy][i] or 0.0
        local boxed = sdk.create_single(v)

        sdk.call_object_func(
            arr,
            "SetValue(System.Object,System.Int32)",
            boxed,
            i
        )
    end

    blast_param:call("set_AddLimit(System.Single[])", arr)
end



function MudaStock(enemy,y,x)

                 

                    if not enemy then return end

               
                    local params = enemy:call("get_DamageParam()")
                    if not params then
                        return
                    end

                    local st = params:call("get_DamageStock()")
                    if not st then
                        return
                    end

                   
                    local count = nil

                    -- Caso List<T>
                    count = st:get_field("_size")

                    -- Caso Array
                    if not count then
                        count = st:call("get_Length")
                    end

                    -- Caso propriedade Count
                    if not count then
                        count = st:call("get_Count")
                    end


                    if not count or count <= 0 then
                        return
                    end

                  
                    for i = 0, count - 1 do
                        local stock = nil

                        -- List<T>
                        stock = st:call("get_Item", i)

                        -- Array fallback
                        if not stock then
                            stock = st[i]
                        end

                        if not stock then goto continue end


                        local ok1, orig = pcall(function()
                            return stock:call("get_OriginalDamage")
                        end)

                        local ok2, dtype = pcall(function()
                            return stock:call("get_DamageType")
                        end)

                        local ok3, cond = pcall(function()
                            return stock:call("get_ConditionDamage")
                        end)

                        
                        

                        local enum_value = sdk.create_int32(4)
                        stock:call("set_ForceConditionDamageType", enum_value)
                        -- 1) Criar array gerenciado de float (Single)
                        local arr = sdk.create_managed_array("System.Single", 18)

                        

                        
                        arr[y] = x

                        -- 3) Chamar o setter
                        stock:call("set_ConditionDamage", arr)


                        ::continue::
                    end



    
end    



function GetPlayerElements()
    -- PlayerManager
    local pm = sdk.get_managed_singleton("snow.player.PlayerManager")
    if not pm then
        return nil, "SEM PLAYER MANAGER"
    end

    -- Player principal
    local player = pm:call("findMasterPlayer()")
    if not player then
        return nil, "SEM MASTERPLAYER"
    end

    -- PlayerData
    local pdata = player:call("get_PlayerData()")
    if not pdata then
        return nil, "SEM PLAYERDATA"
    end

    -- leitura dos campos
    local elements = {
        element_type_1  = pdata:get_field("_ElementType"),
        element_type_2  = pdata:get_field("_ElementType2nd"),
        element_value_1 = pdata:get_field("_ElementAttack"),
        element_value_2 = pdata:get_field("_ElementAttack2nd")
    }

    return elements
end

function reaplicaPara(enemy)

                 local dmg_param = enemy:call("get_DamageParam")
                local ativo = false
                local stock = false
                local enable = false
                if dmg_param then
                    local paralyze_param = dmg_param:get_field("_ParalyzeParam") 
                    ativo = paralyze_param:call("get_IsActive()")
                    stock = paralyze_param:call("get_IsStockEnable()")
                    enable = paralyze_param:call("get_IsUseAddTiredTime()")
                    if timeP[enemy] == nil then
                        contPA[enemy] = false
                        timeP[enemy] = paralyze_param:call("get_ActiveTime()")
                    end    

                    
                    
                    
                end    
                
                
                
                if paralyze_finished[enemy] and ativo ~= true and contPA[enemy] == false and stock == true and timerPA[enemy] then
                    local pv = _G.paralyze_values[enemy]
                    local ns = _G.normalstate_values[enemy]

                   
                    local list = _G.g_paralyze_list or {}
                    local pv = _G.paralyze_values[enemy]
                    local ns = _G.normalstate_values[enemy]
                    local damage_param = enemy:call("get_DamageParam")
                    if damage_param then
                        local paralyze_param = damage_param:get_field("_ParalyzeParam")                        
                        

                        paralyze_param:call("set_ActiveTime(System.Single)",3.0)
                       

                        local activateCount = paralyze_param:call("get_ActivateCount()")
                        local len1 = activateCount:call("get_Length")
                        local arr1 = sdk.create_managed_array("System.Single", len1)
                        for i = 0, len1 - 1 do
                            arr1[i] = len1 - 2
                        end
                        paralyze_param:call("set_ActivateCount(System.Single[])", arr1)

                        local old = paralyze_param:call("get_AddLimit()")
                        if not old then
                            return
                        end

                        local len = old:call("get_Length")

                        
                        local function read_single_array(a)
                            if not a then return nil end

                            local len = a:call("get_Length")
                            if not len or len <= 0 then return {} end

                            local t = {}

                            for i = 0, len - 1 do
                                if a[i] ~= nil then
                                    t[i] = a[i]

                                -- fallback raro: struct com mValue
                                else
                                    local el = a.get_element and a:get_element(i)
                                    if el and el.get_field then
                                        t[i] = el:get_field("mValue")
                                    end
                                end
                            end

                            return t
                        end


                        if addL[enemy] == nil then
                            addL[enemy] = read_single_array(old)
                        end    
                        

                        local arr = sdk.create_managed_array("System.Single", len)

                        for i = 0, len - 1 do
                            arr[i] = 0.0
                        end

                        paralyze_param:call("set_AddLimit(System.Single[])", arr)

                                            


                    end

                    enemy:call(
                        "stockDirectConditionDamage(System.Single, snow.enemy.EnemyDef.ConditionDamageType)",
                        999.0,
                        0
                    )                  
                    if damage_param then
                        local paralyze_param = damage_param:get_field("_ParalyzeParam")    
                        local ati = paralyze_param:call("get_IsActive()")
                        local enable = paralyze_param:call("get_IsEnable()")
                  

                        if ati or enable then
                            contPA[enemy] = true --diz que o colateral está acontecendo
                        end    
                    end    
                end
                start_timer(5.0, function(enemy)
                    if not enemy or not sdk.is_managed_object(enemy) then return end

                    local dmg_param = enemy:call("get_DamageParam")
                    if not dmg_param then return end

                    local para_param = dmg_param:get_field("_ParalyzeParam")
                    if not para_param or not sdk.is_managed_object(para_param) then return end

                    restore_addlimitAndTimer(enemy, para_param)
                end, enemy)

                   local damage_param = enemy:call("get_DamageParam")
                   if damage_param then
                        local paralyze_param = damage_param:get_field("_ParalyzeParam")
                        if contPA[enemy] == false then                   
                            paralyze_param:call("set_ActiveTime(System.Single)",timeP[enemy])
                            

                        end

                    end
end

