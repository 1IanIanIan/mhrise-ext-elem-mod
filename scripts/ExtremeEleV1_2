local function EmitQuestReset()

    for _, fn in pairs(_G.OnQuestReset) do
        pcall(fn)
    end
end


local function ResetQuestState()

    attacker = 0

    -- weak tables → recriar
    sleepOk  = setmetatable({}, { __mode = "k" })
    FireOk   = setmetatable({}, { __mode = "k" })
    fireDmg  = setmetatable({}, { __mode = "k" })
    IceOk    = setmetatable({}, { __mode = "k" })
    baseAtk  = setmetatable({}, { __mode = "k" })

    dragaoTime = setmetatable({}, { __mode = "k" })
    addDragao  = setmetatable({}, { __mode = "k" })
    dragao     = setmetatable({}, { __mode = "k" })
    atvdragao  = setmetatable({}, { __mode = "k" })
    cond_dragao= setmetatable({}, { __mode = "k" })
    drageffect= setmetatable({}, { __mode = "k" })

    BlastDmg = setmetatable({}, { __mode = "k" })
    actBnew  = setmetatable({}, { __mode = "k" })
    actBold  = setmetatable({}, { __mode = "k" })

    contPA = setmetatable({}, { __mode = "k" })
    timerPA = setmetatable({}, { __mode = "k" })

    timeP = setmetatable({}, { __mode = "k" })
    addL  = setmetatable({}, { __mode = "k" })
    addB  = setmetatable({}, { __mode = "k" })

    aguardando_hitdata = {}

    cond_dragao_active = {}
    cond_dragao_last_time = {}

    schedule_effect = nil
    spawn_and_paint_effect = nil

end
local last_active = nil

local quest_hook_installed = false

local function install_quest_hook()
    if quest_hook_installed then return end

    local qm_td = sdk.find_type_definition("snow.QuestManager")
    if not qm_td then
        return
    end

    local method = qm_td:get_method("getActiveQuestUniqueNo")
    if not method then
        return
    end

    sdk.hook(
        method,
        function(args)
            return args
        end,
        function(retval)
            local qm = sdk.get_managed_singleton("snow.QuestManager")
            if not qm then return retval end

            local active = qm:call("isActiveQuest")

            -- primeira execução
            if last_active == nil then
                last_active = active
                return retval
            end

            -- TRANSIÇÃO: quest acabou
            if last_active == true and active == false then
                ResetQuestState()
                EmitQuestReset()      
            end

            last_active = active
            return retval
        end
    )


    quest_hook_installed = true
end

install_quest_hook()




local blighted_enabled = false
local blighted_hook_installed = false
local ELEMENT_TO_CONDITION = {
    [3] = 9,   -- Fire
    [4] = 8,   -- Water
    [5] = 10,  -- Thunder
    [6] = 11   -- Ice
}
function EnableBlightedElement(enable)
    blighted_enabled = enable

    -- instala o hook apenas UMA vez
    if blighted_hook_installed then
        return
    end

    blighted_hook_installed = true

    local EnemyCharacterBase =
        sdk.find_type_definition("snow.enemy.EnemyCharacterBase")
    if not EnemyCharacterBase then
        return
    end

    local stockDamage_method =
        EnemyCharacterBase:get_method("stockDamage")
    if not stockDamage_method then
        return
    end

    sdk.hook(
        stockDamage_method,

        function(args)
            
            if not blighted_enabled then
                return
            end

            -- args[3] = DamageParam
            local damage_param = sdk.to_managed_object(args[3])
            if not damage_param then
                return
            end

            local ok_et, element_type = pcall(function()
                return damage_param:call("get_ElementType")
            end)
            if not ok_et then
                return
            end

            local condition_type =
                ELEMENT_TO_CONDITION[element_type]
            if not condition_type then
                return
            end

            local ok_vital, vital_damage = pcall(function()
                return damage_param:call("get_ElementPartsVitalDamage")
            end)
            if not ok_vital or not vital_damage then
                return
            end

            local ok_attacker, attacker = pcall(function()
                return damage_param:call("get_DamageAttackerType")
            end)
            if attacker == 0 then
                pcall(function()
                    damage_param:call(
                        "set_ConditionDamageType",
                        condition_type
                    )
                    damage_param:call(
                        "set_ConditionDamage",
                        vital_damage * 0.25
                    )
                end)
            end
            args[3] = sdk.to_ptr(damage_param)
        end,

        function(retval)
            return retval
        end
    )
end



function AplicaMultiplicadorElemental(enemy, damage, mult)
    if not enemy or not damage then return end
    mult = mult or 10

    local elementType = damage:call("get_ElementType()")

    local elemDmg = damage:call("get_ElementDamage()")


    if not elemDmg then return end


    if FireOk[enemy] == true and elementType == 3 then
        damage:call(
            "set_ElementDamage(System.Single)",
            elemDmg * 1.15
        )
    end

   
    if IceOk[enemy] == true then
        if elementType ~= 5 then
            damage:call("set_ElementType", 5) -- gelo
            damage:call("set_ConditionDamageType", 10)
            damage:call("set_ConditionDamage",1.0)

            local phys = damage:call("get_PhysicalDamage()") or 0
            local physele= phys * 0.30
            local elementalDamage = damage:call("get_ElementDamage()") or 0
            
            damage:call(
                "set_ElementDamage(System.Single)",elementalDamage + physele)
        end        
    end

    if drageffect[enemy] == 1 then
        damage:call(
            "set_ElementDamage(System.Single)",
            elemDmg * 1.5
        )

    end
end

function OnEnemyStockDamage(args)
    local enemy = sdk.to_managed_object(args[2])
    if not enemy then return end

    if FireOk[enemy] ~= true and IceOk[enemy] ~= true and drageffect[enemy]~= 1 then
        return
    end

    local damage = sdk.to_managed_object(args[3])
    if not damage then return end

    AplicaMultiplicadorElemental(enemy, damage, 10)

    args[3] = sdk.to_ptr(damage)
end

function CriarHookElemental()
    if _G.ElementHookCreated then return end

    local enemyType = sdk.find_type_definition("snow.enemy.EnemyCharacterBase")
    if not enemyType then return end

    local method = enemyType:get_method("stockDamage")
    if not method then return end

    sdk.hook(method, OnEnemyStockDamage)

    _G.ElementHookCreated = true
    _G.ElementHookEnabled = true

end
function SetElementHookEnabled(state)
    _G.ElementHookEnabled = state
end








_G.enemy_status_cache = _G.enemy_status_cache or {}

function get_enemy_key(enemy)
    local uid = enemy:get_field("<UniqueId>k__BackingField")
    if not uid then return nil end
    return tostring(uid)
end

--/ERRO
function compare_enemy_stock(enemy, statusName)
    local key = get_enemy_key(enemy)
    if not key then return nil end

    local data = read_enemy_status(enemy, statusName)
    if not data then return nil end

    _G.enemy_status_cache[key] = _G.enemy_status_cache[key] or {}
    local cache = _G.enemy_status_cache[key]

    cache[statusName] = cache[statusName] or {
        player = data.stock.player,
        wirebug = data.stock.wirebug
    }

    local last = cache[statusName]

    local delta = {
        player = data.stock.player - last.player,
        wirebug = data.stock.wirebug - last.wirebug
    }

    -- Atualiza cache
    last.player  = data.stock.player
    last.wirebug = data.stock.wirebug

    return data, delta
end
function read_enemy_status(enemy, statusName)
    if not enemy or not sdk.is_managed_object(enemy) then
        return nil
    end

    local damage_param = enemy:get_field("<DamageParam>k__BackingField")
    if not damage_param then
        return nil
    end

    local param = damage_param:get_field(statusName)
    if not param then
        return nil
    end

    -- Função auxiliar para arrays player / wirebug
    local function read_array(func)
        local ok, arr = pcall(function()
            return param:call(func)
        end)

        local out = { player = 0, wirebug = 0 }

        if not ok or not arr then
            return out
        end

        if not sdk.is_managed_object(arr) then
            return out
        end

        if arr.get_size == nil or arr.get_element == nil then
            return out
        end

        local size = arr:get_size()

        if size > 0 then
            local e0 = arr:get_element(0)
            if e0 then
                out.player = e0:get_field("mValue") or 0
            end
        end

        if size > 1 then
            local e1 = arr:get_element(1)
            if e1 then
                out.wirebug = e1:get_field("mValue") or 0
            end
        end

        return out
    end


    return {
        is_enable    = param:call("get_IsEnable"),
        is_active    = param:call("get_IsActive"),

        stock        = read_array("get_Stock"),        -- quanto já tomou
        limit        = read_array("get_Limit"),        -- limite atual
        add_limit    = read_array("get_AddLimit"),     -- aumento após proc
        max_limit    = read_array("get_MaxLimit"),

        active_time  = param:call("get_ActiveTime"),
        active_timer = param:call("get_ActiveTimer"),

        type         = param:get_field("<Type>k__BackingField")
    }
end



